<?xml version="1.0" encoding="UTF-8"?>
<!--
  Stesso schema di WebRobot.Sdk/sonatype-settings.example.xml (Portal user token, non OSSRH legacy).
  https://central.sonatype.com/usertoken

  Jenkins: credenziale «Username with password» con ID `sonatype-ossrh` (default SONATYPE_CREDENTIALS_ID).
  Settings Maven: <server><id>ossrh</id> (allineato al pom), distinto dall’ID credenziale Jenkins.
  Locale: sonatype-settings.local.xml (gitignored).
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">
  <servers>
    <server>
      <id>ossrh</id>
      <username>SONATYPE_USERNAME</username>
      <password>SONATYPE_PASSWORD</password>
    </server>
  </servers>
</settings>
